{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "jsx": "preserve",
    "strict": false,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowJs": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@geeklabssh/hive-tablepro/*": ["./*"],
      "@/*": ["./*"]
    }
  },
  "include": ["core/**/*", "models/**/*", "utils/**/*"]
}
