{
  "name": "@geeklabssh/hive-tablepro",
  "version": "3.0.11",
  "description": "Tabelas e UI para ProtonWeb (Tailwind + shadcn/Radix + TanStack Table)",
  "license": "MIT",
  "sideEffects": [
    "./src/styles/globals.css"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/GeekLabsSH/hive-tablepro.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "src",
    "core",
    "models",
    "utils",
    "legacy-rewrite",
    "tailwind.config.ts",
    "postcss.config.cjs",
    "components.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./hive-data-grid-theme.css": "./src/styles/hive-data-grid-theme.css",
    "./styles.css": "./src/styles/globals.css",
    "./table": "./src/table/index.ts",
    "./export": "./src/export/index.ts",
    "./date-picker": "./src/date-picker/index.ts",
    "./lib/utils": "./src/lib/utils.ts",
    "./vite/debug-ingest-plugin": "./vite/hive-tablepro-debug-ingest-plugin.ts",
    "./core/x-data-grid/src": "./core/x-data-grid/src/index.ts",
    "./core/x-data-grid/src/internals": "./core/x-data-grid/src/internals/index.ts",
    "./core/x-data-grid-pro/src": "./core/x-data-grid-pro/src/index.ts",
    "./core/x-data-grid-premium/src": "./core/x-data-grid-premium/src/index.ts",
    "./core/mui-material/src": "./core/mui-material/src/index.ts"
  },
  "scripts": {
    "check-imports": "node ./scripts/extract-imports.mjs",
    "inventory:protonweb": "node ./scripts/protonweb-table-inventory.mjs",
    "legacy:sync": "node ./scripts/ensure-legacy-hive-tablepro.mjs",
    "backlog:legacy-matrix": "node ./scripts/backlog-legacy-matrix.mjs",
    "backlog:execute": "node ./scripts/run-full-backlog.mjs",
    "backlog:execute:all": "node -e \"process.env.RUN_E2E='1'; require('node:child_process').execSync('npm run backlog:execute',{stdio:'inherit',shell:true})\"",
    "legacy:scan-zero": "node ./scripts/legacy-bigbang-scan-zero.mjs",
    "legacy:rewrite-all": "node ./scripts/legacy-bigbang-rewrite-all.mjs",
    "legacy:contract-check": "node ./scripts/legacy-bigbang-contract-check.mjs",
    "legacy:report": "node ./scripts/legacy-bigbang-report.mjs",
    "legacy:bigbang": "node ./scripts/legacy-bigbang-final-gate.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "vite",
    "build:playground": "vite build",
    "preview:playground": "vite preview",
    "prepublishOnly": "npm run typecheck && npm run check-imports && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:storybook": "playwright test -c playwright.storybook.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tailwindcss": "^3.4.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.0.4",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.20.5",
    "@tanstack/react-virtual": "^3.10.8",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^2.30.0",
    "exceljs": "^4.3.0",
    "file-saver": "^2.0.5",
    "react-day-picker": "^8.10.1",
    "recharts": "^2.15.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/file-saver": "^2.0.5",
    "@types/node": "^22.19.17",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.49",
    "react": "^18.2.0",
    "react-dom": "18.2.0",
    "storybook": "^8.6.14",
    "tailwindcss": "^3.4.15",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.2.2",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  }
}
